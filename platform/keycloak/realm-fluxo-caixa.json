{
  "realm": "fluxo-caixa",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "roles": {
    "realm": [
      {
        "name": "merchant",
        "description": "Own merchant lancamentos (write/read)",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "admin",
        "description": "Operational admin (reprocess, reconcile)",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "readonly",
        "description": "Read-only consolidado/consulta",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "defaultDefaultClientScopes": [
    "role_list",
    "profile",
    "email",
    "roles",
    "web-origins",
    "fluxo-claims"
  ],
  "defaultOptionalClientScopes": [
    "offline_access",
    "address",
    "phone",
    "microprofile-jwt"
  ],
  "clientScopes": [
    {
      "name": "fluxo-claims",
      "description": "Custom claims for fluxo-caixa services",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "merchant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "merchant_id",
            "claim.name": "merchant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "svc-lancamentos",
      "name": "svc-lancamentos",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "svc-consolidado",
      "name": "svc-consolidado",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "svc-consulta",
      "name": "svc-consulta",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "krakend",
      "name": "krakend",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "merchant-demo",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Merchant",
      "email": "merchant-demo@fluxo-caixa.local",
      "attributes": {
        "merchant_id": ["00000000-0000-4000-8000-000000000001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "merchant-demo",
          "temporary": false
        }
      ],
      "realmRoles": ["merchant"]
    }
  ]
}
