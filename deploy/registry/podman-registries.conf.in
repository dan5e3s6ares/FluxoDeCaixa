# Podman registry trust — rendered by scripts/lib/registry.sh
# Harbor prepare/install pulls goharbor/* via podman-docker; short names need docker.io.
unqualified-search-registries = ["docker.io"]

[[registry]]
location = "docker.io"

[[registry]]
location = "@HARBOR_REGISTRY@"
insecure = true

[[registry]]
location = "@HARBOR_ALIAS@"
insecure = true

[[registry]]
location = "@HARBOR_ALIAS@:@HARBOR_PORT@"
insecure = true
