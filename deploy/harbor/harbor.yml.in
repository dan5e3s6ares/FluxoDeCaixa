# Harbor in-VM config — rendered by scripts/deploy-registry.sh
# Aligned with goharbor/harbor v2.10.2 make/harbor.yml.tmpl (prepare requires these sections).
hostname: @HARBOR_ALIAS@
external_url: http://@HARBOR_ALIAS@:@HARBOR_PORT@

http:
  port: @HARBOR_PORT@

https:
  port: 443
  certificate: @HARBOR_CERT@
  private_key: @HARBOR_KEY@

harbor_admin_password: @HARBOR_ADMIN_PASSWORD@

database:
  password: root123
  max_idle_conns: 100
  max_open_conns: 900
  conn_max_lifetime: 5m
  conn_max_idle_time: 0

data_volume: @HARBOR_DATA_VOLUME@

# Dev VM: trivy disabled by default (Harbor 2.10+ install.sh omits --with-trivy).
# Set HARBOR_INSTALL_FLAGS=--with-trivy in deploy-registry.sh to enable scanning.
jobservice:
  max_job_workers: 10
  job_loggers:
    - STD_OUTPUT
    - FILE
  logger_sweeper_duration: 1 #days

notification:
  webhook_job_max_retry: 3
  webhook_job_http_client_timeout: 3 #seconds

log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: /var/log/harbor

_version: 2.10.0

upload_purging:
  enabled: true
  age: 168h
  interval: 24h
  dryrun: false

cache:
  enabled: false
  expire_hours: 24

proxy:
  http_proxy:
  https_proxy:
  no_proxy:
  components:
    - core
    - jobservice
    - trivy
